# Reference for Railway (or any host) → backend service → Variables.
# Do not commit real secrets. Copy names into the dashboard; values come from you.

# --- Public URLs (no trailing slash on bases) ---
# API: set PAWHUB_PUBLIC_BASE_URL explicitly, or rely on RAILWAY_PUBLIC_DOMAIN (see PublicBaseUrlFromRailwayRunner).
# PAWHUB_PUBLIC_BASE_URL=https://your-backend-service.up.railway.app
PAWHUB_FRONTEND_BASE_URL=https://your-frontend-service.up.railway.app

# --- Listen port (Railway usually injects PORT automatically; only set if needed) ---
# PORT=8080

# --- Uploads: attach a Volume in Railway and match this path ---
PAWHUB_UPLOAD_DIR=/app/uploads

# --- JWT (required in production) ---
# JWT_SECRET=use-a-long-random-string

# --- MySQL (Railway MySQL plugin sets MYSQL* or use Spring-style vars) ---
# MYSQLHOST=...
# MYSQLPORT=3306
# MYSQLDATABASE=pawhub
# MYSQLUSER=...
# MYSQLPASSWORD=...

# --- Google Gemini (never commit; set only in the host UI) ---
# PAWHUB_GEMINI_API_KEY=...
# PAWHUB_GEMINI_ENABLED=true
# PAWHUB_GEMINI_MODEL=gemini-2.5-flash
# PAWHUB_GEMINI_FALLBACK_MODEL=gemini-2.5-flash-lite
# PAWHUB_GEMINI_WHISKER_MODEL=gemini-2.5-flash
# PAWHUB_GEMINI_FAIL_OPEN_ON_API_ERROR=false

# --- Production hardening ---
# PAWHUB_DEMO_USER_ENABLED=false
# PAWHUB_BOOTSTRAP_PAW_MARKET_SEED=false
# PAWHUB_ADMIN_PASSWORD=use-a-strong-unique-password
# PAWHUB_ADMIN_SYNC_CREDENTIALS_ON_STARTUP=false

# --- Optional email (for real verification / mail) ---
# MAIL_HOST=...
# MAIL_PORT=587
# MAIL_USERNAME=...
# MAIL_PASSWORD=...
# MAIL_FROM=...

# --- Vite (frontend *build* only, in the frontend service) ---
# VITE_API_BASE_URL=https://your-backend-service.up.railway.app
