# Copy to application-secrets.yml (same folder) and paste your key.
# application-secrets.yml is gitignored.
#
# Default Gemini model IDs live in com.pawhub.config.GeminiModelIds (change in one place).
# Optional overrides:
#   model: gemini-3-flash
#   fallback-model: gemini-3.1-flash-lite
#   whisker-model: gemini-3-flash
pawhub:
  gemini:
    api-key: YOUR_GOOGLE_AI_STUDIO_KEY
